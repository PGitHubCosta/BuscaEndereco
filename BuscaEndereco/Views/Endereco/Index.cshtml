@model BuscaEndereco.Models.EnderecoViewModel

@{
    ViewData["Title"] = "Cadastro de Endereço";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="mb-4 text-primary">Buscar e Cadastrar Endereço</h2>
    
    <form asp-controller="Endereco" asp-action="Salvar" method="post" class="p-4 border rounded bg-light shadow-sm">
        
       
        <div class="mb-3">
            <label asp-for="Cep" class="form-label font-weight-bold">Digite o CEP</label>
            <input type="text" asp-for="Cep" id="txtCep" class="form-control" placeholder="Ex: 01001000" maxlength="9" />
            <span asp-validation-for="Cep" class="text-danger small"></span>
            
           
            <small id="statusCep" class="text-muted d-block mt-1">A busca será feita automaticamente ao digitar o CEP.</small>
        </div>

        
        <div class="mb-3">
            <label asp-for="Logradouro" class="form-label font-weight-bold"></label>
            <input asp-for="Logradouro" id="txtLogradouro" class="form-control" readonly style="background-color: #e9ecef;" />
            <span asp-validation-for="Logradouro" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Bairro" class="form-label font-weight-bold"></label>
                <input asp-for="Bairro" id="txtBairro" class="form-control" readonly style="background-color: #e9ecef;" />
                <span asp-validation-for="Bairro" class="text-danger small"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Cidade" class="form-label font-weight-bold"></label>
                <input asp-for="Cidade" id="txtCidade" class="form-control" readonly style="background-color: #e9ecef;" />
                <span asp-validation-for="Cidade" class="text-danger small"></span>
            </div>
            <div class="col-md-2 mb-3">
                <label asp-for="Estado" class="form-label font-weight-bold">UF</label>
                <input asp-for="Estado" id="txtEstado" class="form-control" readonly style="background-color: #e9ecef;" />
                <span asp-validation-for="Estado" class="text-danger small"></span>
            </div>
        </div>

       
        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="Numero" class="form-label font-weight-bold"></label>
                <input asp-for="Numero" class="form-control" placeholder="Ex: 123" />
                <span asp-validation-for="Numero" class="text-danger small"></span>
            </div>
            <div class="col-md-8 mb-3">
                <label asp-for="Complemento" class="form-label font-weight-bold"></label>
                <input asp-for="Complemento" class="form-control" placeholder="Ex: Apto 42" />
            </div>
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-2">Enviar Endereço Completo</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script type="text/javascript">
        document.addEventListener("DOMContentLoaded", function () {
            var inputCep = document.getElementById("txtCep");
            var statusCep = document.getElementById("statusCep");

            // Dispara a busca quando o campo perde o foco ou ao digitar
            inputCep.addEventListener("blur", executarBusca);
            inputCep.addEventListener("input", executarBusca);

            function executarBusca() {
                var cep = inputCep.value.replace(/\D/g, '');

                // Só envia se tiver os 8 dígitos exatos
                if (cep.length === 8) {
                    statusCep.innerHTML = "<span class='text-warning font-weight-bold'>⏳ Servidor buscando endereço...</span>";
                    
                    var urlInterna = "/Endereco/BuscarCep?cep=" + cep;

                    fetch(urlInterna)
                        .then(response => response.json())
                        .then(dados => {
                            // Verifica de todas as formas se o objeto de erro foi retornado
                            if (dados && dados.erro !== true && dados.erro !== "true" && !dados.hasOwnProperty('erro')) {
                                
                                // Preenche os inputs estáticos com segurança
                                document.getElementById("txtLogradouro").value = dados.logradouro || "";
                                document.getElementById("txtBairro").value = dados.bairro || "";
                                document.getElementById("txtCidade").value = dados.localidade || "";
                                document.getElementById("txtEstado").value = dados.uf || "";
                                
                                statusCep.innerHTML = "<span class='text-success font-weight-bold'>✅ Endereço encontrado pelo Servidor!</span>";
                            } else {
                                statusCep.innerHTML = "<span class='text-danger font-weight-bold'>❌ CEP inválido ou não encontrado.</span>";
                                limparCampos();
                            }
                        })
                        .catch(() => {
                            statusCep.innerHTML = "<span class='text-danger font-weight-bold'>❌ Erro interno de comunicação.</span>";
                            limparCampos();
                        });
                }
            }

            function limparCampos() {
                document.getElementById("txtLogradouro").value = "";
                document.getElementById("txtBairro").value = "";
                document.getElementById("txtCidade").value = "";
                document.getElementById("txtEstado").value = "";
            }
        });
    </script>
}
