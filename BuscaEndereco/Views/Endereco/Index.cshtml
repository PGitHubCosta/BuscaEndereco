@model BuscaEndereco.Models.EnderecoViewModel

@{
    ViewData["Title"] = "Cadastro de Endereço";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="mb-4 text-primary">Buscar e Cadastrar Endereço</h2>
    
    <form asp-controller="Endereco" asp-action="Salvar" method="post" class="p-4 border rounded bg-light shadow-sm">
        
        
        <div class="mb-3">
            <label asp-for="Cep" class="form-label font-weight-bold">Digite o CEP</label>
            <input asp-for="Cep" id="txtCep" class="form-control" placeholder="00000-000" maxlength="9" />
            <span asp-validation-for="Cep" class="text-danger small"></span>
           
            <small id="statusCep" class="text-muted d-block mt-1">A busca será feita automaticamente ao digitar o CEP.</small>
        </div>

        
        <div class="mb-3">
            <label asp-for="Logradouro" class="form-label font-weight-bold"></label>
            <input asp-for="Logradouro" id="txtLogradouro" class="form-control" readonly />
            <span asp-validation-for="Logradouro" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Bairro" class="form-label font-weight-bold"></label>
                <input asp-for="Bairro" id="txtBairro" class="form-control" readonly />
                <span asp-validation-for="Bairro" class="text-danger small"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Cidade" class="form-label font-weight-bold"></label>
                <input asp-for="Cidade" id="txtCidade" class="form-control" readonly />
                <span asp-validation-for="Cidade" class="text-danger small"></span>
            </div>
            <div class="col-md-2 mb-3">
                <label asp-for="Estado" class="form-label font-weight-bold">UF</label>
                <input asp-for="Estado" id="txtEstado" class="form-control" readonly />
                <span asp-validation-for="Estado" class="text-danger small"></span>
            </div>
        </div>

        
        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="Numero" class="form-label font-weight-bold"></label>
                <input asp-for="Numero" class="form-control" placeholder="Ex: 123" />
                <span asp-validation-for="Numero" class="text-danger small"></span>
            </div>
            <div class="col-md-8 mb-3">
                <label asp-for="Complemento" class="form-label font-weight-bold"></label>
                <input asp-for="Complemento" class="form-control" placeholder="Ex: Apto 42" />
            </div>
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-2">Enviar Endereço Completo</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script src="https://jquery.com"></script>
    <script src="https://cloudflare.com"></script>
    
    <script>
        $(document).ready(function () {
            
            $('#txtCep').mask('00000-000');

            
            $("#txtCep").on("blur keyup", function () {
                var cep = $(this).val().replace(/\D/g, '');

                if (cep.length === 8) {
                    
                    $("#statusCep").html("<span class='text-warning font-weight-bold'>⏳ Buscando endereço no ViaCEP...</span>");
                    
                    var urlViaCep = "https://viacep.com.br" + cep + "/json/";

                    $.getJSON(urlViaCep, function (dados) {
                        if (!("erro" in dados)) {
                            
                            $("#txtLogradouro").val(dados.logradouro);
                            $("#txtBairro").val(dados.bairro);
                            $("#txtCidade").val(dados.localidade);
                            $("#txtEstado").val(dados.uf);
                            
                            
                            $("#statusCep").html("<span class='text-success font-weight-bold'>✅ Endereço encontrado!</span>");
                        } else {
                            $("#statusCep").html("<span class='text-danger font-weight-bold'>❌ CEP não encontrado.</span>");
                            limparCampos();
                        }
                    }).fail(function() {
                        $("#statusCep").html("<span class='text-danger font-weight-bold'>❌ Erro ao conectar com o serviço.</span>");
                        limparCampos();
                    });
                } else {
                    
                    $("#statusCep").html("A busca será feita automaticamente ao digitar o CEP.");
                }
            });

            function limparCampos() {
                $("#txtLogradouro").val("");
                $("#txtBairro").val("");
                $("#txtCidade").val("");
                $("#txtEstado").val("");
            }
        });
    </script>
}
